OPENROUTER_API_KEY=sk-or-...

# OpenAI — for embeddings (OpenRouter doesn't proxy these) and as fallback chat
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# Chainlit
# Generate the auth secret with: chainlit create-secret
# ─────────────────────────────────────────────────────────────
CHAINLIT_AUTH_SECRET=replace-with-output-of-chainlit-create-secret
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

MCP_SERVER_URL=

# ─────────────────────────────────────────────────────────────
# Observability — LangFuse (recommended; OSS + cloud options)
# ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

ENVIRONMENT=development
LOG_LEVEL=INFO
